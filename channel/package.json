{
  "name": "@tuken/openclaw-channel",
  "version": "0.6.0",
  "description": "tuken channel extension for OpenClaw",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "pack": "node scripts/build.mjs --pack"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.15-beta.1"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "tuken",
      "label": "Tuken",
      "selectionLabel": "Tuken",
      "detailLabel": "Tuken",
      "docsPath": "/channels/tuken",
      "docsLabel": "tuken",
      "blurb": "Connect OpenClaw to Tuken-Hub with baseUrl/appId/appSecret.",
      "systemImage": "hub",
      "order": 999,
      "exposure": {
        "configured": true,
        "setup": true,
        "docs": false
      }
    }
  }
}

