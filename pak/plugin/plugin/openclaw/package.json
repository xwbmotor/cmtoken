{
  "name": "@clawbot-hub/openclaw-channel",
  "version": "v0.6.0",
  "description": "clawbot-hub channel extension for OpenClaw",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.15-beta.1"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "clawbot-hub",
      "label": "ClawBot Hub",
      "selectionLabel": "ClawBot Hub",
      "detailLabel": "ClawBot Hub",
      "docsPath": "/channels/clawbot-hub",
      "docsLabel": "clawbot-hub",
      "blurb": "Connect OpenClaw to ClawBot-Hub with baseUrl/appId/appSecret.",
      "systemImage": "hub",
      "order": 999,
      "exposure": {
        "configured": true,
        "setup": true,
        "docs": false
      }
    }
  }
}
