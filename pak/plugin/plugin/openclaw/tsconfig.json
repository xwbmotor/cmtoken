{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": ["./*.ts", "./src/**/*.ts", "./src/**/*.d.ts"],
  "exclude": ["./dist/**", "./node_modules/**", "./**/*.test.ts"]
}
